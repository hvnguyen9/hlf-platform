generator client {
  provider = "prisma-client-js"
  output   = "../prisma-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  name           String?
  role           UserRole       @default(USER)
  discordWebhook String?
  emailEnabled   Boolean        @default(true)
  thresholds           Json?
  watchedPortfolioIds  Json?
  subscriptions        Subscription[]
  alerts         Alert[]
  positions      UserPosition[]
  tickers        Ticker[]       @relation("UserTickers")
  hiddenTickers  HiddenTicker[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

model Ticker {
  id            String         @id @default(cuid())
  symbol        String         @unique
  name          String
  sector        String?
  isApproved    Boolean        @default(false)
  lastPrice     Float?
  lastUpdated   DateTime?
  createdBy     String?
  priceBars     PriceBar[]
  subscriptions Subscription[]
  alerts        Alert[]
  positions     UserPosition[]
  hiddenBy      HiddenTicker[]
  creator       User?          @relation("UserTickers", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())

  @@index([createdBy])
}

model HiddenTicker {
  userId   String
  tickerId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker   Ticker @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@id([userId, tickerId])
}

model PriceBar {
  id       String   @id @default(cuid())
  tickerId String
  date     DateTime @db.Date
  open     Float
  high     Float
  low      Float
  close    Float
  volume   BigInt
  ticker   Ticker   @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@unique([tickerId, date])
  @@index([tickerId, date])
}

model Subscription {
  id               String   @id @default(cuid())
  userId           String
  tickerId         String
  customThresholds Json?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker           Ticker   @relation(fields: [tickerId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@unique([userId, tickerId])
}

model Alert {
  id       String    @id @default(cuid())
  userId   String
  tickerId String
  type     AlertType
  signals  Json
  message  String
  sentAt   DateTime  @default(now())
  channel  String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker   Ticker    @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
}

enum AlertType {
  CSP_OPPORTUNITY
  CC_OPPORTUNITY
  SUPPORT_BREAK
  RESISTANCE_BREAK
  VOLUME_SURGE
  SMA_CROSS_UP
  SMA_CROSS_DOWN
  PROFIT_TARGET
  ASSIGNMENT_RISK
  ROLL_OPPORTUNITY
}

enum PositionType {
  CSP
  CC
  STOCK
}

model UserPosition {
  id             String       @id @default(cuid())
  userId         String
  tickerId       String
  positionType   PositionType
  contracts      Int          @default(1)
  strikePrice    Float?
  premium        Float?
  shares         Int?
  entryPrice     Float?
  expirationDate DateTime?
  notes          String?
  openedAt       DateTime     @default(now())
  closedAt       DateTime?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker         Ticker       @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@index([userId, tickerId])
  @@index([userId, closedAt])
}
