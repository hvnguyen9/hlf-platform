generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User identity lives in the shared auth DB (@hlf/auth-db). userId here is
// an opaque string referencing User.id in that DB; no FK constraint.

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  yearMonth String   // "YYYY-MM"
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, yearMonth])
  @@index([userId])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  ticker    String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, ticker])
  @@index([userId])
}

model Portfolio {
  id                  String               @id @default(cuid())
  name                String
  userId              String
  startingCapital     Decimal              @default(0)
  createdAt           DateTime             @default(now())
  notes               String?
  updatedAt           DateTime?            @updatedAt
  trades              Trade[]
  stockLot            StockLot[]
  capitalTransactions CapitalTransaction[]

  @@index([userId])
}

model CapitalTransaction {
  id          String          @id @default(cuid())
  portfolioId String
  portfolio   Portfolio       @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Decimal         @db.Decimal(18, 2)
  note        String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  @@index([portfolioId])
}

enum TransactionType {
  deposit
  withdrawal
}

model Trade {
  id               String      @id @default(cuid())
  ticker           String
  strikePrice      Float
  expirationDate   DateTime
  type             TradeType
  contracts        Int
  contractPrice    Float
  entryPrice       Float?
  status           TradeStatus @default(open)
  closedAt         DateTime?
  closingPrice     Float?
  premiumCaptured  Float?
  percentPL        Float?
  portfolioId      String
  createdAt        DateTime    @default(now())
  notes            String?
  contractsInitial Int
  contractsOpen    Int
  closeReason      CloseReason?
  portfolio        Portfolio   @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  stockLot         StockLot?   @relation(fields: [stockLotId], references: [id])
  stockLotId       String?

  @@index([status, portfolioId])
  @@index([portfolioId, status, closedAt])
  @@index([expirationDate, portfolioId])
  @@index([ticker, portfolioId])
}

enum TradeType {
  Put
  Call
  CoveredCall
  CashSecuredPut
}

enum TradeStatus {
  open
  closed
}

enum CloseReason {
  manual
  expiredWorthless
  assigned
}

model StockLot {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  ticker  String
  shares  Int
  avgCost Decimal @db.Decimal(18, 6) // per-share cost basis

  status StockLotStatus @default(OPEN)

  openedAt DateTime  @default(now())
  closedAt DateTime?

  closePrice  Decimal? @db.Decimal(18, 6)
  realizedPnl Decimal? @db.Decimal(18, 2)

  notes String? // <-- NEW

  trades Trade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portfolioId, ticker])
  @@index([portfolioId, status])
  @@index([portfolioId, closedAt])
}

enum StockLotStatus {
  OPEN
  CLOSED
}

// ─── Alerts module (added 2026-05-13) ───────────────────────────────────────
// Realtime, position-aware alerts. Web Push primary, optional email fallback.
// Scan endpoint hit by an external scheduler (GitHub Actions) during market
// hours. Configs are inline on trade detail and watchlist rows in the UI.
// userId fields remain opaque references to @hlf/auth-db User.id (no FK).

model UserAlertPreferences {
  userId          String   @id
  pushEnabled     Boolean  @default(true)
  emailEnabled    Boolean  @default(false)
  emailAddress    String?  // optional override; defaults to auth-DB email
  quietHoursStart Int?     // 0-23 in user's tz
  quietHoursEnd   Int?     // 0-23 in user's tz
  timezone        String   @default("America/New_York")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  @@index([userId])
}

model AlertConfig {
  id              String          @id @default(cuid())
  userId          String
  type            AlertConfigType

  // For trade-bound configs (PROFIT_TARGET / ASSIGNMENT_RISK / ROLL_OPPORTUNITY).
  // Not an FK on purpose — keeps the config row around if the trade is hard-deleted.
  tradeId         String?

  // For watchlist-bound configs (WATCHLIST_BREACH).
  watchlistTicker String?

  // For lot-bound configs (LOT_PRICE_BREACH).
  stockLotId      String?

  // Type-specific params, JSON:
  //   PROFIT_TARGET     { profitPct }
  //   ASSIGNMENT_RISK   { withinPctOfStrike, maxDte }
  //   ROLL_OPPORTUNITY  { maxDte, minOtmPct }
  //   WATCHLIST_BREACH  { triggerPrice, direction: "below" | "above" }
  //   LOT_PRICE_BREACH  { mode: "absolute" | "pctBelowAvg" | "pctAboveAvg",
  //                       triggerPrice?, pct?, direction?: "below" | "above" }
  params          Json

  enabled         Boolean         @default(true)
  lastFiredAt     DateTime?       // dedup window anchor
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  events          AlertEvent[]

  @@index([userId, enabled])
  @@index([tradeId])
  @@index([userId, watchlistTicker])
  @@index([userId, stockLotId])
}

enum AlertConfigType {
  PROFIT_TARGET
  ASSIGNMENT_RISK
  ROLL_OPPORTUNITY
  WATCHLIST_BREACH
  LOT_PRICE_BREACH
}

model AlertEvent {
  id             String      @id @default(cuid())
  configId       String
  userId         String
  message        String
  priceAtFire    Float
  pushDelivered  Boolean     @default(false)
  emailDelivered Boolean     @default(false)
  firedAt        DateTime    @default(now())
  config         AlertConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([userId, firedAt])
  @@index([configId])
}
