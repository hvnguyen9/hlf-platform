{
  "expo": {
    "name": "HLF",
    "slug": "hlf-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "hlf",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hlfinancialstrategies.mobile"
    },
    "android": {
      "package": "com.hlfinancialstrategies.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#10b981"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ed44d8b4-d5f5-4b9a-a314-64010400f5c5"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ed44d8b4-d5f5-4b9a-a314-64010400f5c5"
    }
  }
}
