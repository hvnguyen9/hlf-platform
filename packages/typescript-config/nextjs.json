{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "jsx": "preserve",
    "noEmit": true
  },
  "include": [
    "src",
    "app",
    "pages",
    "components",
    "lib",
    "features",
    "data",
    "server",
    "scripts",
    "next.config.ts",
    "next.config.js",
    "next-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
