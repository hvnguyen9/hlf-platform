# Hoist Babel + Expo's Metro stack to the workspace-root node_modules so
# Babel's classical Node.js plugin resolution walks find them. Without
# this, `eas update` and `expo export` fail in our pnpm monorepo with
# "Cannot find module @babel/plugin-transform-*" errors — pnpm's strict
# symlink layout hides transitive Babel plugins from Babel itself.
#
# This is the workaround Expo's own monorepo docs recommend:
# https://docs.expo.dev/guides/monorepos/
public-hoist-pattern[]=*babel-plugin*
public-hoist-pattern[]=*babel-preset*
public-hoist-pattern[]=@babel/*
public-hoist-pattern[]=*metro*
public-hoist-pattern[]=@expo/*
